{
  "info": {
    "_postman_id": "d1a2b3c4-e5f6-7890-abcd-ef1234567890",
    "name": "Digital Art Gallery Management System",
    "description": "Complete Postman collection for the Digital Art Gallery Management System REST API. Set the `token` collection variable after login to authenticate protected requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "artistId",
      "value": "",
      "type": "string"
    },
    {
      "key": "artworkId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "exhibitionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@gallery.com\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user. Role can be 'admin', 'artist', or 'user'."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  console.log('Token saved to collection variable.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gallery.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with email and password. The token is automatically saved to the collection variable on success."
          }
        }
      ]
    },
    {
      "name": "Artists",
      "item": [
        {
          "name": "Create Artist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"artistName\": \"Leonardo DiVinci\",\n  \"specialization\": \"Digital Painting\",\n  \"bio\": \"A passionate digital artist with over 10 years of experience in creating breathtaking digital paintings and illustrations.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/artists",
              "host": ["{{baseUrl}}"],
              "path": ["api", "artists"]
            },
            "description": "Create an artist profile for the authenticated user. Requires 'admin' or 'artist' role."
          }
        },
        {
          "name": "Get All Artists",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/artists",
              "host": ["{{baseUrl}}"],
              "path": ["api", "artists"]
            },
            "description": "Retrieve all artist profiles."
          }
        },
        {
          "name": "Get Artist By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/artists/{{artistId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "artists", "{{artistId}}"]
            },
            "description": "Retrieve a single artist by their ID."
          }
        },
        {
          "name": "Update Artist",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"artistName\": \"Leonardo DiVinci Updated\",\n  \"specialization\": \"3D Digital Art\",\n  \"bio\": \"An experienced 3D digital artist specializing in immersive environments and character design.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/artists/{{artistId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "artists", "{{artistId}}"]
            },
            "description": "Update an artist profile. Artists can only update their own profile; admins can update any."
          }
        },
        {
          "name": "Delete Artist",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/artists/{{artistId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "artists", "{{artistId}}"]
            },
            "description": "Delete an artist profile. Admin only."
          }
        }
      ]
    },
    {
      "name": "Artworks",
