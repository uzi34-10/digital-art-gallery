              "path": ["api", "artworks", "{{artworkId}}"]
            },
            "description": "Get a single artwork by ID with full populated data."
          }
        },
        {
          "name": "Update Artwork",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sunset Dreams - Revised Edition\",\n  \"price\": 2000,\n  \"description\": \"An updated and more detailed depiction of a coastal sunset.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/artworks/{{artworkId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "artworks", "{{artworkId}}"]
            },
            "description": "Update artwork fields. Artists can only update their own artworks."
          }
        },
        {
          "name": "Delete Artwork",
