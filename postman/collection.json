            "url": {
              "raw": "{{baseUrl}}/api/artworks?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "artworks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Get all artworks with pagination."
