            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sunset Dreams\",\n  \"description\": \"A vibrant sunset painting capturing the golden hues of twilight over the ocean.\",\n  \"price\": 1500,\n  \"category\": \"{{categoryId}}\",\n  \"artistId\": \"{{artistId}}\"\n}"
